# ============================================================
#  Sewage Treatment Plant Maintenance Log — configuration
#  Copy this file to ".env" and adjust the values.
# ============================================================

# Secret used to sign session cookies and CSRF tokens.
# MUST be changed for production. Generate one with:
#   python -c "import secrets; print(secrets.token_urlsafe(48))"
SECRET_KEY=change-me-please-generate-a-long-random-value

# Database connection. SQLite by default (file lives in ./data).
# To use PostgreSQL later:  postgresql+psycopg://user:pass@host/dbname
DATABASE_URL=sqlite:///./data/app.db

# Where uploaded images are stored.
UPLOAD_DIR=./data/uploads

# Where backup ZIPs are written (Step 3).
BACKUP_DIR=./data/backups

# Default language: de or en
DEFAULT_LANGUAGE=de

# Set to "true" ONLY behind HTTPS. When true, session cookies are
# marked Secure. Geolocation + speech input require HTTPS in browsers.
SECURE_COOKIES=false

# Server bind address / port (used by uvicorn / systemd).
HOST=0.0.0.0
PORT=8000

# Reminder threshold: assets whose next maintenance is due within this
# many days are highlighted as "due soon".
REMINDER_DUE_SOON_DAYS=30

# Max upload size per image in megabytes.
MAX_UPLOAD_MB=10

# Auto-create an initial admin account on first startup if no users exist.
# Change the password immediately after first login.
BOOTSTRAP_ADMIN_USERNAME=admin
BOOTSTRAP_ADMIN_PASSWORD=changeme
